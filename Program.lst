000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "6502.inc"
000000r 2               ; =============================================================================
000000r 2               ;   6502.inc — External include file for the 6502 system
000000r 2               ; =============================================================================
000000r 2               ;
000000r 2               ;   CPU:       WDC 65C02
000000r 2               ;   BIOS:      v1.0
000000r 2               ;   Assembler: ca65 (cc65 toolchain) — uses := for absolute symbols
000000r 2               ;
000000r 2               ;   Include this file in external projects to access Kernal routines,
000000r 2               ;   IO hardware registers, system variables, and useful constants.
000000r 2               ;
000000r 2               ;   MEMORY MAP
000000r 2               ;   ----------
000000r 2               ;   $0000-$0003   Zero Page: System pointers (see below)
000000r 2               ;   $0004-$0023   Zero Page: Reserved by BASIC interpreter
000000r 2               ;   $0024-$0035   Zero Page: System scratch (CF, serial, delay, monitor)
000000r 2               ;   $0036-$00FF   Zero Page: Free for user programs
000000r 2               ;   $0100-$01FF   CPU Stack
000000r 2               ;   $0200-$02FF   Input Buffer (ring buffer, managed by Kernal)
000000r 2               ;   $0300-$03FF   Kernal Variables (vectors, cursor, HW flags, etc.)
000000r 2               ;   $0400-$07FF   User Variables / BASIC workspace
000000r 2               ;   $0800-$7FFF   Program RAM (30 KB — load address for user code)
000000r 2               ;   $8000-$83FF   IO 1: Banked RAM Low  (256 × ~1 KB banks)
000000r 2               ;   $8400-$87FF   IO 2: Banked RAM High (256 × ~1 KB banks)
000000r 2               ;   $8800-$881F   IO 3: RTC (DS1511Y)
000000r 2               ;   $8C00-$8C07   IO 4: Storage (CompactFlash, 8-bit IDE)
000000r 2               ;   $9000-$9003   IO 5: Serial (R65C51 ACIA)
000000r 2               ;   $9400-$940F   IO 6: GPIO (65C22 VIA — keyboard & joysticks)
000000r 2               ;   $9800-$981C   IO 7: Sound (SID / ARMSID)
000000r 2               ;   $9C00-$9C01   IO 8: Video (TMS9918 / pico9918)
000000r 2               ;   $A000-$A0FF   Kernal Jump Table (stable entry points)
000000r 2               ;   $A100-$B7FF   Kernal Implementation
000000r 2               ;   $B800-$BFFF   Character Set ROM (2 KB, 256 × 8-byte patterns)
000000r 2               ;   $C000-$E7FF   BASIC Interpreter
000000r 2               ;   $E800-$FEFF   Machine Code Monitor
000000r 2               ;   $FF00-$FFF9   Wozmon (mini monitor)
000000r 2               ;   $FFFA-$FFFF   CPU Vectors (NMI, RESET, IRQ)
000000r 2               ;
000000r 2               ;   BOOT SEQUENCE
000000r 2               ;   -------------
000000r 2               ;   On RESET the BIOS probes all eight IO slots, initializes detected
000000r 2               ;   hardware, and auto-selects video or serial console.  If neither is
000000r 2               ;   found, IO_MODE is left unchanged (no halt — cartridges with their
000000r 2               ;   own display hardware can still boot).  A startup beep plays (if SID
000000r 2               ;   is present) for audible feedback, then BOOT_VECTOR ($035B) is
000000r 2               ;   checked — if non-zero, execution jumps there (cartridge takeover).
000000r 2               ;   Otherwise a console check halts if no video/serial is found, then
000000r 2               ;   the splash screen and boot menu are displayed.  ENTER launches
000000r 2               ;   BASIC; ESC enters the Monitor.  A 5-second timeout auto-boots BASIC.
000000r 2               ;
000000r 2               ;   CARTRIDGE SUPPORT
000000r 2               ;   -----------------
000000r 2               ;   Cartridges overlay $C000-$FFFF (BASIC, Monitor, Wozmon, vectors).
000000r 2               ;   The Kernal ($A000-$B7FF) and character set ($B800-$BFFF) remain
000000r 2               ;   accessible.  Use KernalInit ($A072) to initialize all hardware and
000000r 2               ;   return via RTS — interrupts are left disabled so the cart can set
000000r 2               ;   up its own handlers first.  See usage patterns in the BIOS README.
000000r 2               ;
000000r 2               ;   IO_MODE
000000r 2               ;   -------
000000r 2               ;   Bit 0 of IO_MODE selects the console output device:
000000r 2               ;     0 = Video (TMS9918)    1 = Serial (R65C51)
000000r 2               ;   Chrout ($A000) dispatches automatically based on IO_MODE.
000000r 2               ;   Use SetIOMode / GetIOMode to change or query the active console.
000000r 2               ;
000000r 2               ;   CALLING CONVENTION
000000r 2               ;   ------------------
000000r 2               ;   Kernal routines are called via JSR to the jump table addresses below.
000000r 2               ;   Parameters are passed in A, X, Y, and/or zero-page pointers as
000000r 2               ;   documented per routine.  Carry flag is used for success/error returns
000000r 2               ;   (C=0 success, C=1 error) where noted.
000000r 2               ;
000000r 2               ;   HW_PRESENT BITMASK
000000r 2               ;   -------------------
000000r 2               ;   After boot, HW_PRESENT ($030D) contains a bitmask of detected hardware.
000000r 2               ;   Test individual bits before calling hardware-specific routines.
000000r 2               ;   Example:
000000r 2               ;     lda HW_PRESENT
000000r 2               ;     and #HW_VID          ; Is video card present?
000000r 2               ;     beq @NoVideo         ; Skip if not
000000r 2               ;
000000r 2               ; =============================================================================
000000r 2               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 1: ZERO PAGE POINTERS
000000r 2               ; =============================================================================
000000r 2               ; These zero page locations are used by the Kernal.  External programs may
000000r 2               ; use STR_PTR and CF_BUF_PTR/CF_LBA as parameters to Kernal calls.
000000r 2               ; Locations $36-$FF are free for user programs.
000000r 2               
000000r 2               STR_PTR             := $02               ; 2 bytes — String pointer (used by FsLoadFile, FsSaveFile, FsDeleteFile, etc.)
000000r 2               CF_BUF_PTR          := $24               ; 2 bytes — CF sector data buffer pointer
000000r 2               CF_LBA              := $26               ; 4 bytes — CF 28-bit LBA address (little-endian)
000000r 2               
000000r 2               ; Safe zero page range for user programs:
000000r 2               ; $36-$FF (202 bytes free)
000000r 2               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 2: SYSTEM VARIABLES ($0300-$03FF)
000000r 2               ; =============================================================================
000000r 2               
000000r 2               IRQ_PTR             := $0300             ; 2 bytes — IRQ handler vector (writable; default: internal Irq handler)
000000r 2               BRK_PTR             := $0302             ; 2 bytes — BRK handler vector (writable; default: enters Monitor)
000000r 2               NMI_PTR             := $0304             ; 2 bytes — NMI handler vector (writable; default: RTI)
000000r 2               
000000r 2               IO_MODE             := $0306             ; 1 byte  — Console output mode (bit 0: 0=video, 1=serial)
000000r 2               VID_CURSOR_X        := $0307             ; 1 byte  — Video cursor column (0-39)
000000r 2               VID_CURSOR_Y        := $0308             ; 1 byte  — Video cursor row (0-23)
000000r 2               
000000r 2               HW_PRESENT          := $030D             ; 1 byte  — Hardware present bitmask (set during boot probe)
000000r 2               
000000r 2               ; HW_PRESENT bit definitions (bit order matches IO slot numbers):
000000r 2               HW_RAM_L            = %00000001          ; Bit 0: RAM card low  (IO 1, $8000-$83FF)
000000r 2               HW_RAM_H            = %00000010          ; Bit 1: RAM card high (IO 2, $8400-$87FF)
000000r 2               HW_RTC              = %00000100          ; Bit 2: RTC card      (IO 3, DS1511Y)
000000r 2               HW_CF               = %00001000          ; Bit 3: Storage card   (IO 4, CompactFlash)
000000r 2               HW_SC               = %00010000          ; Bit 4: Serial card    (IO 5, R65C51)
000000r 2               HW_GPIO             = %00100000          ; Bit 5: GPIO card      (IO 6, 65C22 VIA — keyboard/joysticks)
000000r 2               HW_SID              = %01000000          ; Bit 6: Sound card     (IO 7, SID/ARMSID)
000000r 2               HW_VID              = %10000000          ; Bit 7: Video card     (IO 8, TMS9918/pico9918)
000000r 2               
000000r 2               ; BRK register save area (populated by the BRK handler before entering Monitor):
000000r 2               BRK_P               := $0310             ; Saved processor status (P)
000000r 2               BRK_PCL             := $0311             ; Saved PC low byte (points to BRK instruction + 2)
000000r 2               BRK_PCH             := $0312             ; Saved PC high byte
000000r 2               BRK_A               := $0313             ; Saved accumulator
000000r 2               BRK_X               := $0314             ; Saved X register
000000r 2               BRK_Y               := $0315             ; Saved Y register
000000r 2               BRK_SP              := $0316             ; Saved stack pointer
000000r 2               
000000r 2               ; RTC scratch (used by RtcWriteDate to pass century):
000000r 2               RTC_BUF_CENT        := $030B             ; Century value for RtcReadDate / RtcWriteDate
000000r 2               
000000r 2               ; Cartridge / boot redirect vector:
000000r 2               BOOT_VECTOR         := $035B             ; 2 bytes — Boot redirect address (0=normal boot)
000000r 2                                                        ;   Set after KernalInit to redirect Reset flow
000000r 2                                                        ;   KernalInit zeroes this; write after init returns
000000r 2               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 3: KEY MEMORY LOCATIONS
000000r 2               ; =============================================================================
000000r 2               
000000r 2               INPUT_BUFFER        := $0200             ; $0200-$02FF — 256-byte ring buffer (keyboard/serial input)
000000r 2               PROGRAM_START       := $0800             ; User programs and BASIC programs load here
000000r 2               ;                                        ; Program space extends to $7FFF (30 KB)
000000r 2               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 4: KERNAL JUMP TABLE ($A000-$A0FF)
000000r 2               ; =============================================================================
000000r 2               ; All entry points are stable 3-byte JMP instructions.  Call via JSR.
000000r 2               ; Unimplemented slots return immediately (RTS).
000000r 2               
000000r 2               ; --- Character I/O ---
000000r 2               Chrout              := $A000             ; Output character (dispatched by IO_MODE)
000000r 2                                                        ;   In: A = character
000000r 2                                                        ;   Preserves: A, X, Y
000000r 2                                                        ;   Handles CR ($0D), LF ($0A), BS ($08), BEL ($07) in video mode
000000r 2               
000000r 2               Chrin               := $A003             ; Input character from buffer (non-blocking poll)
000000r 2                                                        ;   Out: A = character, C=1 if char available, C=0 if not
000000r 2                                                        ;   Caller must loop until C=1 for blocking behavior
000000r 2                                                        ;   Echoes character via Chrout
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               WriteBuffer         := $A006             ; Write byte to input ring buffer
000000r 2                                                        ;   In: A = byte to write
000000r 2                                                        ;   Modifies: X
000000r 2               
000000r 2               ReadBuffer          := $A009             ; Read byte from input ring buffer
000000r 2                                                        ;   Out: A = byte read
000000r 2                                                        ;   Modifies: X, A
000000r 2               
000000r 2               BufferSize          := $A00C             ; Get number of unread bytes in input buffer
000000r 2                                                        ;   Out: A = count
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               ; --- IO Mode ---
000000r 2               SetIOMode           := $A00F             ; Set IO_MODE
000000r 2                                                        ;   In: A = mode (bit 0: 0=video, 1=serial)
000000r 2               
000000r 2               GetIOMode           := $A012             ; Get IO_MODE
000000r 2                                                        ;   Out: A = current IO_MODE
000000r 2               
000000r 2               ; --- Video (TMS9918 / pico9918) ---
000000r 2               InitVideo           := $A015             ; Initialize TMS9918 (text mode, 40×24)
000000r 2                                                        ;   Modifies: A, X
000000r 2               
000000r 2               VideoClear          := $A018             ; Clear screen (fill with spaces), reset cursor to (0,0)
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               VideoPutChar        := $A01B             ; Write character at cursor position (no cursor advance)
000000r 2                                                        ;   In: A = character
000000r 2               
000000r 2               VideoSetCursor      := $A01E             ; Set cursor position
000000r 2                                                        ;   In: X = column (0-39), Y = row (0-23)
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               VideoGetCursor      := $A021             ; Get cursor position
000000r 2                                                        ;   Out: X = column (0-39), Y = row (0-23)
000000r 2               
000000r 2               VideoScroll         := $A024             ; Scroll screen up one line, clear bottom row
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               VideoSetColor       := $A027             ; Set TMS9918 text color
000000r 2                                                        ;   In: A = color byte (high nibble = foreground, low nibble = background)
000000r 2                                                        ;   See TMS9918 Color Constants below
000000r 2               
000000r 2               VideoChroutRaw      := $A02A             ; Output char to video with no control-code handling
000000r 2                                                        ;   In: A = character code (0-255)
000000r 2                                                        ;   Preserves: A, X, Y
000000r 2                                                        ;   Always renders glyph, never interprets CR/LF/BS/BEL
000000r 2               
000000r 2               ; --- Sound (SID / ARMSID) ---
000000r 2               InitSID             := $A02D             ; Initialize SID (clear all registers, volume=15)
000000r 2                                                        ;   Modifies: A, X
000000r 2               
000000r 2               Beep                := $A030             ; Play short beep tone (~475 Hz)
000000r 2                                                        ;   Skips silently if no SID detected
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               SidPlayNote         := $A033             ; Play note on a SID voice
000000r 2                                                        ;   In: A = voice (0-2), X = freq low, Y = freq high
000000r 2                                                        ;   Uses triangle waveform, ADSR: A=0 D=9 S=A R=2
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               SidSilence          := $A036             ; Silence all 3 SID voices (gate off, zero freq)
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               SidSetVolume        := $A039             ; Set SID master volume
000000r 2                                                        ;   In: A = volume (0-15)
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               ; --- Filesystem (simple 16-file directory on CF) ---
000000r 2               ;   Directory lives at LBA 0 (512 bytes, 16 × 32-byte entries).
000000r 2               ;   Data sectors start at LBA 1.
000000r 2               ;   Filenames are 8.3 format, space-padded, case-insensitive.
000000r 2               ;   Pass null-terminated "NAME.EXT" string via STR_PTR ($02-$03).
000000r 2               
000000r 2               FsLoadFile          := $A03C             ; Load file from CF
000000r 2                                                        ;   In: STR_PTR = pointer to null-terminated filename
000000r 2                                                        ;   Out: C=0 success, C=1 not found or error
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               FsSaveFile          := $A03F             ; Save file to CF
000000r 2                                                        ;   In: STR_PTR = pointer to null-terminated filename
000000r 2                                                        ;   Out: C=0 success, C=1 error
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               FsDeleteFile        := $A042             ; Delete file from CF
000000r 2                                                        ;   In: STR_PTR = pointer to null-terminated filename
000000r 2                                                        ;   Out: C=0 success, C=1 not found or error
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               ; --- Keyboard / GPIO ---
000000r 2               InitKB              := $A045             ; Initialize VIA for keyboard input
000000r 2                                                        ;   Configures Port A/B as inputs, enables CB1/CA1 IRQs
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               ; --- Joysticks ---
000000r 2               ReadJoystick1       := $A048             ; Read joystick 1 (VIA Port B)
000000r 2                                                        ;   Out: A = bitmask (active-low bits, active bits depend on wiring)
000000r 2                                                        ;   Temporarily disables matrix keyboard encoder
000000r 2               
000000r 2               ReadJoystick2       := $A04B             ; Read joystick 2 (VIA Port A)
000000r 2                                                        ;   Out: A = bitmask (active-low bits, active bits depend on wiring)
000000r 2                                                        ;   Temporarily disables PS/2 keyboard encoder
000000r 2               
000000r 2               ; --- Serial (R65C51) ---
000000r 2               InitSC              := $A04E             ; Initialize serial card (8-N-1, 19200 baud)
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               SerialChrout        := $A051             ; Direct serial output (bypasses IO_MODE)
000000r 2                                                        ;   In: A = character
000000r 2                                                        ;   Blocks until TX register is empty
000000r 2               
000000r 2               ; --- Serial Transfer ---
000000r 2               AsciiLoad           := $A054             ; Receive raw binary via serial into PROGRAM_START
000000r 2                                                        ;   Protocol: 2-byte size (lo/hi), then raw data bytes
000000r 2                                                        ;   Temporarily switches IO_MODE to serial
000000r 2                                                        ;   Out: C=0 success
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               AsciiSave           := $A057             ; Send program memory as raw binary via serial
000000r 2                                                        ;   Protocol: 2-byte size (lo/hi), then raw data bytes
000000r 2                                                        ;   Sends from PROGRAM_START to BAS_PRGEND
000000r 2                                                        ;   Temporarily switches IO_MODE to serial
000000r 2                                                        ;   Out: C=0 success
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               ; --- RTC (DS1511Y) ---
000000r 2               RtcReadTime         := $A05A             ; Read current time
000000r 2                                                        ;   Out: A = hours, X = minutes, Y = seconds (all binary)
000000r 2               
000000r 2               RtcReadDate         := $A05D             ; Read current date
000000r 2                                                        ;   Out: A = day, X = month, Y = year (all binary)
000000r 2                                                        ;   RTC_BUF_CENT ($030B) = century
000000r 2               
000000r 2               RtcWriteTime        := $A060             ; Set RTC time
000000r 2                                                        ;   In: A = hours, X = minutes, Y = seconds (all binary)
000000r 2                                                        ;   Modifies: A, X
000000r 2               
000000r 2               RtcWriteDate        := $A063             ; Set RTC date
000000r 2                                                        ;   In: A = day, X = month, Y = year (all binary)
000000r 2                                                        ;   RTC_BUF_CENT ($030B) must hold century
000000r 2                                                        ;   Modifies: A, X
000000r 2               
000000r 2               RtcReadNVRAM        := $A066             ; Read byte from DS1511Y NVRAM (256 bytes)
000000r 2                                                        ;   In: X = address ($00-$FF)
000000r 2                                                        ;   Out: A = data byte
000000r 2               
000000r 2               RtcWriteNVRAM       := $A069             ; Write byte to DS1511Y NVRAM
000000r 2                                                        ;   In: X = address ($00-$FF), A = data byte
000000r 2               
000000r 2               ; --- CompactFlash Storage ---
000000r 2               StReadSector        := $A06C             ; Read one 512-byte sector
000000r 2                                                        ;   In: CF_LBA ($26-$29) = LBA, CF_BUF_PTR ($24-$25) = dest
000000r 2                                                        ;   Out: C=0 success, C=1 error; CF_BUF_PTR advanced by 512
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               StWriteSector       := $A06F             ; Write one 512-byte sector
000000r 2                                                        ;   In: CF_LBA ($26-$29) = LBA, CF_BUF_PTR ($24-$25) = source
000000r 2                                                        ;   Out: C=0 success, C=1 error; CF_BUF_PTR advanced by 512
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               StWaitReady         := $A072             ; Wait for CF to become ready (BSY=0, RDY=1)
000000r 2                                                        ;   Out: C=0 ready, C=1 timeout/error
000000r 2                                                        ;   Modifies: A, X, Y
000000r 2               
000000r 2               ; --- Timing ---
000000r 2               SysDelay            := $A075             ; Delay for specified centiseconds (10 ms units)
000000r 2                                                        ;   In: A = low byte, X = high byte (16-bit count)
000000r 2                                                        ;   Uses VIA T1 if available, else software loop
000000r 2                                                        ;   Modifies: A
000000r 2               
000000r 2               ; --- System / Cartridge Support ---
000000r 2               KernalInit          := $A078             ; Initialize all hardware (vectors, probe & init all I/O)
000000r 2                                                        ;   Caller MUST reset the stack pointer before JSR:
000000r 2                                                        ;     ldx #$ff / txs / jsr KernalInit
000000r 2                                                        ;   Zeroes BOOT_VECTOR, sets HW_PRESENT, IO_MODE, IRQ/BRK/NMI ptrs
000000r 2                                                        ;   Does NOT reset the stack pointer
000000r 2                                                        ;   Does NOT enable interrupts (caller must CLI)
000000r 2                                                        ;   Does NOT play beep, display splash, or enter boot menu
000000r 2                                                        ;   Does NOT halt if no console is detected
000000r 2                                                        ;   Modifies: All registers, flags
000000r 2               
000000r 2               KernalVersion       := $A07B             ; Get BIOS version
000000r 2                                                        ;   Out: A = major version, X = minor version
000000r 2               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 5: IO HARDWARE REGISTERS
000000r 2               ; =============================================================================
000000r 2               
000000r 2               ; --- Banked RAM Low (IO 1: $8000-$83FF) ---
000000r 2               ;   256 banks × ~1 KB each.  Write bank number to latch, then access data window.
000000r 2               RAM_DATA_L          := $8000             ; R/W data window ($8000-$83FE)
000000r 2               RAM_BANK_L          := $83FF             ; Write-only bank latch ($00-$FF)
000000r 2               
000000r 2               ; --- Banked RAM High (IO 2: $8400-$87FF) ---
000000r 2               RAM_DATA_H          := $8400             ; R/W data window ($8400-$87FE)
000000r 2               RAM_BANK_H          := $87FF             ; Write-only bank latch ($00-$FF)
000000r 2               
000000r 2               ; --- RTC (DS1511Y) (IO 3: $8800-$881F) ---
000000r 2               RTC_SEC             := $8800             ; Seconds      (BCD, 00-59)
000000r 2               RTC_MIN             := $8801             ; Minutes      (BCD, 00-59)
000000r 2               RTC_HR              := $8802             ; Hours        (BCD, 00-23, 24h mode)
000000r 2               RTC_DAY             := $8803             ; Day of week  (1-7)
000000r 2               RTC_DATE            := $8804             ; Day of month (BCD, 01-31)
000000r 2               RTC_MON             := $8805             ; Month        (BCD, 01-12)
000000r 2               RTC_YR              := $8806             ; Year         (BCD, 00-99)
000000r 2               RTC_CENT            := $8807             ; Century      (BCD, 00-39)
000000r 2               RTC_ALARM_SEC       := $8808             ; Alarm seconds
000000r 2               RTC_ALARM_MIN       := $8809             ; Alarm minutes
000000r 2               RTC_ALARM_HR        := $880A             ; Alarm hours
000000r 2               RTC_ALARM_DATE      := $880B             ; Alarm day of month
000000r 2               RTC_WD_L            := $880C             ; Watchdog low
000000r 2               RTC_WD_H            := $880D             ; Watchdog high
000000r 2               RTC_CTRL_A          := $880E             ; Control Register A
000000r 2               RTC_CTRL_B          := $880F             ; Control Register B
000000r 2               RTC_RAM_ADDR        := $8810             ; NVRAM address register
000000r 2               RTC_RAM_DATA        := $8813             ; NVRAM data register
000000r 2               ; Control Register B bits:
000000r 2               RTC_CTRL_B_TE       := %10000000         ; Transfer Enable — set to inhibit clock updates during write
000000r 2               
000000r 2               ; --- CompactFlash / Storage (IO 4: $8C00-$8C07) ---
000000r 2               ;   8-bit IDE (True IDE) mode.  The BIOS issues Set Features $01 at boot
000000r 2               ;   to enable 8-bit data transfers.
000000r 2               ST_DATA             := $8C00             ; R/W — Data register
000000r 2               ST_ERROR            := $8C01             ; Read — Error register
000000r 2               ST_FEATURE          := $8C01             ; Write — Feature register
000000r 2               ST_SECT_CNT         := $8C02             ; R/W — Sector count
000000r 2               ST_LBA_0            := $8C03             ; R/W — LBA bits 0-7
000000r 2               ST_LBA_1            := $8C04             ; R/W — LBA bits 8-15
000000r 2               ST_LBA_2            := $8C05             ; R/W — LBA bits 16-23
000000r 2               ST_LBA_3            := $8C06             ; R/W — LBA bits 24-27 + drive/mode
000000r 2               ST_STATUS           := $8C07             ; Read — Status register
000000r 2               ST_CMD              := $8C07             ; Write — Command register
000000r 2               
000000r 2               ; CF Status Register bits:
000000r 2               ST_STATUS_ERR       := %00000001         ; Error occurred
000000r 2               ST_STATUS_IDX       := %00000010         ; Index mark
000000r 2               ST_STATUS_CORR      := %00000100         ; Corrected data
000000r 2               ST_STATUS_DRQ       := %00001000         ; Data request — ready for data transfer
000000r 2               ST_STATUS_DSC       := %00010000         ; Drive seek complete
000000r 2               ST_STATUS_DWF       := %00100000         ; Drive write fault
000000r 2               ST_STATUS_RDY       := %01000000         ; Drive ready
000000r 2               ST_STATUS_BSY       := %10000000         ; Drive busy — all other bits invalid while set
000000r 2               
000000r 2               ; CF Error Register bits:
000000r 2               ST_ERR_AMNF         := %00000001         ; Address mark not found
000000r 2               ST_ERR_ABRT         := %00000100         ; Command aborted
000000r 2               ST_ERR_IDNF         := %00010000         ; ID not found
000000r 2               ST_ERR_UNC          := %01000000         ; Uncorrectable data error
000000r 2               ST_ERR_BBK          := %10000000         ; Bad block detected
000000r 2               
000000r 2               ; ATA Command bytes:
000000r 2               ST_CMD_READ         := $20               ; Read Sectors
000000r 2               ST_CMD_WRITE        := $30               ; Write Sectors
000000r 2               ST_CMD_SET_FEAT     := $EF               ; Set Features
000000r 2               ST_FEAT_8BIT        := $01               ; Feature: Enable 8-bit data I/O
000000r 2               ST_LBA3_MASTER      := $E0               ; LBA mode, master drive (bits 7-5=111, bit 4=0)
000000r 2               
000000r 2               ; Filesystem constants:
000000r 2               FS_DIR_LBA          = 0                  ; Directory sector at LBA 0
000000r 2               FS_DATA_START       = 1                  ; Data sectors start at LBA 1
000000r 2               FS_MAX_FILES        = 16                 ; Maximum directory entries
000000r 2               FS_ENTRY_SIZE       = 32                 ; Bytes per directory entry
000000r 2               FS_ENTRY_FLAGS      = 11                 ; Offset: flags byte within entry
000000r 2               FS_ENTRY_START      = 12                 ; Offset: start sector (2 bytes, little-endian)
000000r 2               FS_ENTRY_FSIZE      = 14                 ; Offset: file size (2 bytes, little-endian)
000000r 2               FS_FLAG_USED        = %00000001          ; Flags bit 0: entry in use
000000r 2               
000000r 2               ; --- Serial Card (R65C51 ACIA) (IO 5: $9000-$9003) ---
000000r 2               ;   Default config after InitSC: 8-N-1, 19200 baud, RX IRQ enabled
000000r 2               SC_DATA             := $9000             ; R/W — Data register
000000r 2               SC_RESET            := $9001             ; Write — Programmatic reset (write any value)
000000r 2               SC_STATUS           := $9001             ; Read — Status register
000000r 2               SC_CMD              := $9002             ; R/W — Command register
000000r 2               SC_CTRL             := $9003             ; R/W — Control register
000000r 2               
000000r 2               ; Serial Status Register bits:
000000r 2               SC_STATUS_IRQ       := %10000000         ; Interrupt occurred
000000r 2               SC_STATUS_DSR       := %01000000         ; Data Set Ready
000000r 2               SC_STATUS_DCD       := %00100000         ; Data Carrier Detect
000000r 2               SC_STATUS_TDRE      := %00010000         ; TX Data Register Empty (ready to send)
000000r 2               SC_STATUS_RDRF      := %00001000         ; RX Data Register Full (byte available)
000000r 2               SC_STATUS_OVR       := %00000100         ; Overrun error
000000r 2               SC_STATUS_FRME      := %00000010         ; Framing error
000000r 2               SC_STATUS_PARE      := %00000001         ; Parity error
000000r 2               
000000r 2               ; --- GPIO / Input Board (65C22 VIA) (IO 6: $9400-$940F) ---
000000r 2               ;   Port B = matrix keyboard / joystick 1
000000r 2               ;   Port A = PS/2 keyboard / joystick 2
000000r 2               ;   CB1/CA1 IRQs fire when a key scancode is ready
000000r 2               GPIO_PORTB          := $9400             ; Port B data (active keyboard/joystick 1 data)
000000r 2               GPIO_PORTA          := $9401             ; Port A data (active keyboard/joystick 2 data)
000000r 2               GPIO_DDRB           := $9402             ; Port B data direction (0=input, 1=output per bit)
000000r 2               GPIO_DDRA           := $9403             ; Port A data direction
000000r 2               GPIO_T1CL           := $9404             ; Timer 1 counter low (read=counter, write=latch)
000000r 2               GPIO_T1CH           := $9405             ; Timer 1 counter high (write starts timer)
000000r 2               GPIO_T1LL           := $9406             ; Timer 1 latch low
000000r 2               GPIO_T1LH           := $9407             ; Timer 1 latch high
000000r 2               GPIO_T2CL           := $9408             ; Timer 2 counter low
000000r 2               GPIO_T2CH           := $9409             ; Timer 2 counter high
000000r 2               GPIO_SR             := $940A             ; Shift register
000000r 2               GPIO_ACR            := $940B             ; Auxiliary control register
000000r 2               GPIO_PCR            := $940C             ; Peripheral control register
000000r 2               GPIO_IFR            := $940D             ; Interrupt flag register
000000r 2               GPIO_IER            := $940E             ; Interrupt enable register
000000r 2               GPIO_ORA            := $940F             ; Port A (no handshake)
000000r 2               
000000r 2               ; VIA Peripheral Control Register (PCR) mode bits:
000000r 2               GPIO_PCR_CB2_LO     := %11000000         ; CB2 = manual output low  (enable matrix keyboard encoder)
000000r 2               GPIO_PCR_CB2_HI     := %11100000         ; CB2 = manual output high (disable matrix keyboard encoder)
000000r 2               GPIO_PCR_CB1_NEG    := %00000000         ; CB1 = active on falling edge
000000r 2               GPIO_PCR_CA2_LO     := %00001100         ; CA2 = manual output low  (enable PS/2 keyboard encoder)
000000r 2               GPIO_PCR_CA2_HI     := %00001110         ; CA2 = manual output high (disable PS/2 keyboard encoder)
000000r 2               GPIO_PCR_CA1_NEG    := %00000000         ; CA1 = active on falling edge
000000r 2               
000000r 2               ; VIA Interrupt flag/enable bits:
000000r 2               GPIO_INT_CB1        := %00010000         ; Bit 4: CB1 interrupt (matrix keyboard data ready)
000000r 2               GPIO_INT_CA1        := %00000010         ; Bit 1: CA1 interrupt (PS/2 keyboard data ready)
000000r 2               GPIO_IER_SET        := %10000000         ; IER bit 7: 1=set named bits, 0=clear named bits
000000r 2               
000000r 2               ; --- Sound Card (SID / ARMSID) (IO 7: $9800-$981C) ---
000000r 2               ;   MOS 6581/8580 compatible.  3 voices, each with independent frequency,
000000r 2               ;   pulse width, waveform, and ADSR envelope.  Global filter and volume.
000000r 2               
000000r 2               ; Voice 1:
000000r 2               SID_V1_FREQ_LO      := $9800             ; Frequency low byte
000000r 2               SID_V1_FREQ_HI      := $9801             ; Frequency high byte
000000r 2               SID_V1_PW_LO        := $9802             ; Pulse width low byte (bits 0-7)
000000r 2               SID_V1_PW_HI        := $9803             ; Pulse width high nibble (bits 0-3)
000000r 2               SID_V1_CTRL         := $9804             ; Control register (waveform + gate)
000000r 2               SID_V1_AD           := $9805             ; Attack (high nibble) / Decay (low nibble)
000000r 2               SID_V1_SR           := $9806             ; Sustain (high nibble) / Release (low nibble)
000000r 2               
000000r 2               ; Voice 2:
000000r 2               SID_V2_FREQ_LO      := $9807
000000r 2               SID_V2_FREQ_HI      := $9808
000000r 2               SID_V2_PW_LO        := $9809
000000r 2               SID_V2_PW_HI        := $980A
000000r 2               SID_V2_CTRL         := $980B
000000r 2               SID_V2_AD           := $980C
000000r 2               SID_V2_SR           := $980D
000000r 2               
000000r 2               ; Voice 3:
000000r 2               SID_V3_FREQ_LO      := $980E
000000r 2               SID_V3_FREQ_HI      := $980F
000000r 2               SID_V3_PW_LO        := $9810
000000r 2               SID_V3_PW_HI        := $9811
000000r 2               SID_V3_CTRL         := $9812
000000r 2               SID_V3_AD           := $9813
000000r 2               SID_V3_SR           := $9814
000000r 2               
000000r 2               ; Global SID registers:
000000r 2               SID_FC_LO           := $9815             ; Filter cutoff low (bits 0-2)
000000r 2               SID_FC_HI           := $9816             ; Filter cutoff high (bits 0-7)
000000r 2               SID_RES_FILT        := $9817             ; Resonance (high nibble) / Filter enable per voice (bits 0-2)
000000r 2               SID_MODE_VOL        := $9818             ; Filter mode (high nibble) / Master volume (low nibble, 0-15)
000000r 2               SID_PADDLE_X        := $9819             ; Paddle X (read-only)
000000r 2               SID_PADDLE_Y        := $981A             ; Paddle Y (read-only)
000000r 2               SID_OSC3            := $981B             ; Oscillator 3 output (read-only)
000000r 2               SID_ENV3            := $981C             ; Envelope 3 output (read-only)
000000r 2               
000000r 2               ; SID Voice Control Register bits (apply to SID_Vn_CTRL):
000000r 2               SID_CTRL_GATE       := %00000001         ; Gate: 1=start attack, 0=start release
000000r 2               SID_CTRL_SYNC       := %00000010         ; Hard sync with preceding voice
000000r 2               SID_CTRL_RING       := %00000100         ; Ring modulation with preceding voice
000000r 2               SID_CTRL_TEST       := %00001000         ; Test bit (resets oscillator)
000000r 2               SID_CTRL_TRIANGLE   := %00010000         ; Triangle waveform
000000r 2               SID_CTRL_SAWTOOTH   := %00100000         ; Sawtooth waveform
000000r 2               SID_CTRL_PULSE      := %01000000         ; Pulse waveform
000000r 2               SID_CTRL_NOISE      := %10000000         ; Noise waveform
000000r 2               
000000r 2               ; SID Filter Mode bits (high nibble of SID_MODE_VOL):
000000r 2               SID_FILT_LP         := %00010000         ; Low-pass filter
000000r 2               SID_FILT_BP         := %00100000         ; Band-pass filter
000000r 2               SID_FILT_HP         := %01000000         ; High-pass filter
000000r 2               SID_FILT_3OFF       := %10000000         ; Disconnect voice 3 from output
000000r 2               
000000r 2               ; --- SID Frequency Table (1 MHz clock, equal temperament) ---
000000r 2               ;   Freq register = round(Hz × 16777216 / 1000000)
000000r 2               ;   Covers octaves 2-7 (C2=65 Hz to B7=3951 Hz), all 12 chromatic notes.
000000r 2               ;   Sharps and flats are provided as aliases (e.g. SID_NOTE_CS4 = SID_NOTE_Db4).
000000r 2               ;   Use SidPlayNote: A=voice (0-2), X=freq low byte, Y=freq high byte.
000000r 2               ;   Example: ldx #<SID_NOTE_A4 / ldy #>SID_NOTE_A4
000000r 2               
000000r 2               ; Octave 2 (C2=65.41 Hz .. B2=123.47 Hz)
000000r 2               SID_NOTE_C2         = $0449              ; ~65 Hz
000000r 2               SID_NOTE_CS2        = $048B              ; ~69 Hz
000000r 2               SID_NOTE_Db2        = SID_NOTE_CS2
000000r 2               SID_NOTE_D2         = $04D0              ; ~73 Hz
000000r 2               SID_NOTE_DS2        = $0519              ; ~78 Hz
000000r 2               SID_NOTE_Eb2        = SID_NOTE_DS2
000000r 2               SID_NOTE_E2         = $0567              ; ~82 Hz
000000r 2               SID_NOTE_F2         = $05B9              ; ~87 Hz
000000r 2               SID_NOTE_FS2        = $0610              ; ~93 Hz
000000r 2               SID_NOTE_Gb2        = SID_NOTE_FS2
000000r 2               SID_NOTE_G2         = $066C              ; ~98 Hz
000000r 2               SID_NOTE_GS2        = $06CE              ; ~104 Hz
000000r 2               SID_NOTE_Ab2        = SID_NOTE_GS2
000000r 2               SID_NOTE_A2         = $0735              ; ~110 Hz
000000r 2               SID_NOTE_AS2        = $07A3              ; ~117 Hz
000000r 2               SID_NOTE_Bb2        = SID_NOTE_AS2
000000r 2               SID_NOTE_B2         = $0817              ; ~123 Hz
000000r 2               
000000r 2               ; Octave 3 (C3=130.81 Hz .. B3=246.94 Hz)
000000r 2               SID_NOTE_C3         = $0893              ; ~131 Hz
000000r 2               SID_NOTE_CS3        = $0915              ; ~139 Hz
000000r 2               SID_NOTE_Db3        = SID_NOTE_CS3
000000r 2               SID_NOTE_D3         = $099F              ; ~147 Hz
000000r 2               SID_NOTE_DS3        = $0A32              ; ~156 Hz
000000r 2               SID_NOTE_Eb3        = SID_NOTE_DS3
000000r 2               SID_NOTE_E3         = $0ACD              ; ~165 Hz
000000r 2               SID_NOTE_F3         = $0B72              ; ~175 Hz
000000r 2               SID_NOTE_FS3        = $0C20              ; ~185 Hz
000000r 2               SID_NOTE_Gb3        = SID_NOTE_FS3
000000r 2               SID_NOTE_G3         = $0CD8              ; ~196 Hz
000000r 2               SID_NOTE_GS3        = $0D9C              ; ~208 Hz
000000r 2               SID_NOTE_Ab3        = SID_NOTE_GS3
000000r 2               SID_NOTE_A3         = $0E6B              ; ~220 Hz
000000r 2               SID_NOTE_AS3        = $0F46              ; ~233 Hz
000000r 2               SID_NOTE_Bb3        = SID_NOTE_AS3
000000r 2               SID_NOTE_B3         = $102F              ; ~247 Hz
000000r 2               
000000r 2               ; Octave 4 (C4=261.63 Hz .. B4=493.88 Hz) — middle octave
000000r 2               SID_NOTE_C4         = $1125              ; ~262 Hz (Middle C)
000000r 2               SID_NOTE_CS4        = $122A              ; ~277 Hz
000000r 2               SID_NOTE_Db4        = SID_NOTE_CS4
000000r 2               SID_NOTE_D4         = $133F              ; ~294 Hz
000000r 2               SID_NOTE_DS4        = $1464              ; ~311 Hz
000000r 2               SID_NOTE_Eb4        = SID_NOTE_DS4
000000r 2               SID_NOTE_E4         = $159A              ; ~330 Hz
000000r 2               SID_NOTE_F4         = $16E3              ; ~349 Hz
000000r 2               SID_NOTE_FS4        = $183F              ; ~370 Hz
000000r 2               SID_NOTE_Gb4        = SID_NOTE_FS4
000000r 2               SID_NOTE_G4         = $19B1              ; ~392 Hz
000000r 2               SID_NOTE_GS4        = $1B38              ; ~415 Hz
000000r 2               SID_NOTE_Ab4        = SID_NOTE_GS4
000000r 2               SID_NOTE_A4         = $1CD6              ; ~440 Hz (Concert A)
000000r 2               SID_NOTE_AS4        = $1E8D              ; ~466 Hz
000000r 2               SID_NOTE_Bb4        = SID_NOTE_AS4
000000r 2               SID_NOTE_B4         = $205E              ; ~494 Hz
000000r 2               
000000r 2               ; Octave 5 (C5=523.25 Hz .. B5=987.77 Hz)
000000r 2               SID_NOTE_C5         = $224B              ; ~523 Hz
000000r 2               SID_NOTE_CS5        = $2455              ; ~554 Hz
000000r 2               SID_NOTE_Db5        = SID_NOTE_CS5
000000r 2               SID_NOTE_D5         = $267E              ; ~587 Hz
000000r 2               SID_NOTE_DS5        = $28C8              ; ~622 Hz
000000r 2               SID_NOTE_Eb5        = SID_NOTE_DS5
000000r 2               SID_NOTE_E5         = $2B34              ; ~659 Hz
000000r 2               SID_NOTE_F5         = $2DC6              ; ~698 Hz
000000r 2               SID_NOTE_FS5        = $307F              ; ~740 Hz
000000r 2               SID_NOTE_Gb5        = SID_NOTE_FS5
000000r 2               SID_NOTE_G5         = $3361              ; ~784 Hz
000000r 2               SID_NOTE_GS5        = $366F              ; ~831 Hz
000000r 2               SID_NOTE_Ab5        = SID_NOTE_GS5
000000r 2               SID_NOTE_A5         = $39AC              ; ~880 Hz
000000r 2               SID_NOTE_AS5        = $3D1A              ; ~932 Hz
000000r 2               SID_NOTE_Bb5        = SID_NOTE_AS5
000000r 2               SID_NOTE_B5         = $40BC              ; ~988 Hz
000000r 2               
000000r 2               ; Octave 6 (C6=1046.50 Hz .. B6=1975.53 Hz)
000000r 2               SID_NOTE_C6         = $4495              ; ~1047 Hz
000000r 2               SID_NOTE_CS6        = $48A9              ; ~1109 Hz
000000r 2               SID_NOTE_Db6        = SID_NOTE_CS6
000000r 2               SID_NOTE_D6         = $4CFC              ; ~1175 Hz
000000r 2               SID_NOTE_DS6        = $518F              ; ~1245 Hz
000000r 2               SID_NOTE_Eb6        = SID_NOTE_DS6
000000r 2               SID_NOTE_E6         = $5669              ; ~1319 Hz
000000r 2               SID_NOTE_F6         = $5B8C              ; ~1397 Hz
000000r 2               SID_NOTE_FS6        = $60FE              ; ~1480 Hz
000000r 2               SID_NOTE_Gb6        = SID_NOTE_FS6
000000r 2               SID_NOTE_G6         = $66C2              ; ~1568 Hz
000000r 2               SID_NOTE_GS6        = $6CDF              ; ~1661 Hz
000000r 2               SID_NOTE_Ab6        = SID_NOTE_GS6
000000r 2               SID_NOTE_A6         = $7358              ; ~1760 Hz
000000r 2               SID_NOTE_AS6        = $7A34              ; ~1865 Hz
000000r 2               SID_NOTE_Bb6        = SID_NOTE_AS6
000000r 2               SID_NOTE_B6         = $8178              ; ~1976 Hz
000000r 2               
000000r 2               ; Octave 7 (C7=2093.00 Hz .. A7=3520.00 Hz; B7 overflows 16-bit register)
000000r 2               SID_NOTE_C7         = $892B              ; ~2093 Hz
000000r 2               SID_NOTE_CS7        = $9153              ; ~2217 Hz
000000r 2               SID_NOTE_Db7        = SID_NOTE_CS7
000000r 2               SID_NOTE_D7         = $99F7              ; ~2349 Hz
000000r 2               SID_NOTE_DS7        = $A31F              ; ~2489 Hz
000000r 2               SID_NOTE_Eb7        = SID_NOTE_DS7
000000r 2               SID_NOTE_E7         = $ACD2              ; ~2637 Hz
000000r 2               SID_NOTE_F7         = $B719              ; ~2794 Hz
000000r 2               SID_NOTE_FS7        = $C1FC              ; ~2960 Hz
000000r 2               SID_NOTE_Gb7        = SID_NOTE_FS7
000000r 2               SID_NOTE_G7         = $CD85              ; ~3136 Hz
000000r 2               SID_NOTE_GS7        = $D9BD              ; ~3322 Hz
000000r 2               SID_NOTE_Ab7        = SID_NOTE_GS7
000000r 2               SID_NOTE_A7         = $E6B0              ; ~3520 Hz
000000r 2               SID_NOTE_AS7        = $F467              ; ~3729 Hz
000000r 2               SID_NOTE_Bb7        = SID_NOTE_AS7
000000r 2               ; Note: B7 (~3951 Hz = $102F0) exceeds the 16-bit SID register — not defined
000000r 2               
000000r 2               ; --- Video Card (TMS9918 / pico9918) (IO 8: $9C00-$9C01) ---
000000r 2               ;   Text mode: 40 columns × 24 rows.  Name table at VRAM $0000 (960 bytes).
000000r 2               ;   Pattern table at VRAM $0800 (2 KB, 256 × 8-byte character patterns).
000000r 2               ;   To write to a VRAM address: write low byte to VC_REG, then (high | $40) to VC_REG.
000000r 2               ;   To read from a VRAM address: write low byte to VC_REG, then high byte to VC_REG.
000000r 2               ;   Register writes: write data byte to VC_REG, then (reg# | $80) to VC_REG.
000000r 2               VC_DATA             := $9C00             ; R/W — VRAM data (auto-increments address)
000000r 2               VC_REG              := $9C01             ; Write — Address/register port
000000r 2               VC_STATUS           := $9C01             ; Read — Status register
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   SECTION 6: USEFUL CONSTANTS
000000r 2               ; =============================================================================
000000r 2               
000000r 2               ; --- BIOS Version ---
000000r 2               BIOS_VERSION_MAJOR  = 1
000000r 2               BIOS_VERSION_MINOR  = 0
000000r 2               
000000r 2               ; --- ASCII Control Characters ---
000000r 2               CHAR_BEL            = $07                ; Bell (Beep via SID)
000000r 2               CHAR_BS             = $08                ; Backspace (cursor left + erase in video mode)
000000r 2               CHAR_LF             = $0A                ; Line Feed (cursor down, scroll if at bottom)
000000r 2               CHAR_CR             = $0D                ; Carriage Return (cursor to column 0)
000000r 2               CHAR_ESC            = $1B                ; Escape
000000r 2               CHAR_SPACE          = $20                ; Space
000000r 2               
000000r 2               ; --- Video Dimensions ---
000000r 2               VID_COLS            = 40                 ; Screen width in columns
000000r 2               VID_ROWS            = 24                 ; Screen height in rows
000000r 2               VID_NAME_TABLE      = $0000              ; VRAM address of name table (40×24 = 960 bytes)
000000r 2               VID_PATTERN_TABLE   = $0800              ; VRAM address of pattern/character table (2048 bytes)
000000r 2               
000000r 2               ; --- TMS9918 Color Constants (for VideoSetColor) ---
000000r 2               ;   Pass as: (foreground << 4) | background
000000r 2               ;   Example: white on black = $F0, green on black = $20
000000r 2               TMS_TRANSPARENT     = $0
000000r 2               TMS_BLACK           = $1
000000r 2               TMS_MED_GREEN       = $2
000000r 2               TMS_LT_GREEN        = $3
000000r 2               TMS_DK_BLUE         = $4
000000r 2               TMS_LT_BLUE         = $5
000000r 2               TMS_DK_RED          = $6
000000r 2               TMS_CYAN            = $7
000000r 2               TMS_MED_RED         = $8
000000r 2               TMS_LT_RED          = $9
000000r 2               TMS_DK_YELLOW       = $A
000000r 2               TMS_LT_YELLOW       = $B
000000r 2               TMS_DK_GREEN        = $C
000000r 2               TMS_MAGENTA         = $D
000000r 2               TMS_GRAY            = $E
000000r 2               TMS_WHITE           = $F
000000r 2               
000000r 2               ; --- Monitor Entry Points ---
000000r 2               ;   The machine code monitor lives at $C000 and is entered normally via BRK.
000000r 2               ;   These are useful if you want to jump there directly.
000000r 2               MONITOR_ENTRY       := $C000             ; Cold entry (from boot menu or user code)
000000r 2               MONITOR_BRK_ENTRY   := $C003             ; BRK entry (displays saved registers)
000000r 2               
000000r 1               
000000r 1               .segment "CODE"
000000r 1               
000000r 1               ; =============================================================================
000000r 1               ;   BASIC Startup Stub
000000r 1               ; =============================================================================
000000r 1               ;   A tokenized BASIC line: 10 SYS 2060
000000r 1               ;   When this program is loaded into $0800 and RUN in BASIC, the SYS command
000000r 1               ;   jumps to the machine code entry point at $080C (decimal 2060).
000000r 1               ;   This stub must remain at the very start of the program.
000000r 1               
000000r 1  0A 08 0A 00  BasicStartup: .byte $0A, $08, $0A, $00, $9E, $32, $30, $36, $30, $00, $00, $00
000004r 1  9E 32 30 36  
000008r 1  30 00 00 00  
00000Cr 1               
00000Cr 1               ; =============================================================================
00000Cr 1               ;   Start — Program entry point ($080C)
00000Cr 1               ; =============================================================================
00000Cr 1               ;   The system is already fully initialized when your program runs:
00000Cr 1               ;     - Hardware probed and initialized (HW_PRESENT is set)
00000Cr 1               ;     - Interrupts enabled, keyboard active
00000Cr 1               ;     - IO_MODE set (video or serial console)
00000Cr 1               ;     - All Kernal jump table routines available
00000Cr 1               ;
00000Cr 1               ;   Return to BASIC with RTS.
00000Cr 1               ; =============================================================================
00000Cr 1               
00000Cr 1               Start:
00000Cr 1                 ; === Your program starts here ===
00000Cr 1               
00000Cr 1                 ; Example: clear screen and print a message
00000Cr 1  20 18 A0       jsr VideoClear                ; Clear video screen
00000Fr 1               
00000Fr 1  A9 rr          lda #<HelloMsg
000011r 1  85 02          sta STR_PTR
000013r 1  A9 rr          lda #>HelloMsg
000015r 1  85 03          sta STR_PTR + 1
000017r 1  20 rr rr       jsr PrintStr                  ; Print the message
00001Ar 1               
00001Ar 1               @WaitKey:
00001Ar 1  20 03 A0       jsr Chrin                     ; Poll for a keypress (non-blocking)
00001Dr 1  90 FB          bcc @WaitKey                  ; Loop until character available (C=1)
00001Fr 1               
00001Fr 1  20 18 A0       jsr VideoClear                ; Clear screen before returning
000022r 1  60             rts                           ; Return to BASIC
000023r 1               
000023r 1               ; =============================================================================
000023r 1               ;   PrintStr — Print a null-terminated string via Chrout
000023r 1               ;   In: STR_PTR ($02-$03) = pointer to string
000023r 1               ; =============================================================================
000023r 1               PrintStr:
000023r 1  A0 00          ldy #$00
000025r 1               @PrintLoop:
000025r 1  B1 02          lda (STR_PTR),y
000027r 1  F0 06          beq @PrintDone                ; Null terminator — done
000029r 1  20 00 A0       jsr Chrout
00002Cr 1  C8             iny
00002Dr 1  D0 F6          bne @PrintLoop                ; Max 256 chars per call
00002Fr 1               @PrintDone:
00002Fr 1  60             rts
000030r 1               
000030r 1               ; =============================================================================
000030r 1               ;   Data
000030r 1               ; =============================================================================
000030r 1               
000030r 1               HelloMsg:
000030r 1  48 65 6C 6C    .byte "Hello from Program!", CHAR_CR, CHAR_LF
000034r 1  6F 20 66 72  
000038r 1  6F 6D 20 50  
000045r 1  50 72 65 73    .byte "Press any key to return to BASIC.", CHAR_CR, CHAR_LF, $00
000049r 1  73 20 61 6E  
00004Dr 1  79 20 6B 65  
000068r 1               
